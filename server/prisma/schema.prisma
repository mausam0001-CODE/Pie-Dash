// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model SocialAccount {
  id           String   @id @default(cuid())
  platform     String   // 'instagram', 'tiktok', 'facebook', 'youtube'
  username     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Post {
  id            String   @id @default(cuid())
  title         String?
  caption       String
  mediaUrl      String?
  mediaType     String   @default("IMAGE")
  thumbnailUrl  String?
  category      String   @default("Uncategorized")
  tags          String[] // Prisma supports arrays for many providers
  platforms     String   // Stored as comma-separated string or JSON string
  visibility    String   @default("Public")
  status        String   @default("Scheduled") // "Scheduled", "Published", "Draft", "Failed"
  externalId    String?
  scheduledAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
